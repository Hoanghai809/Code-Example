class HistEncoder(nn.Module):
    """MLP encoder cho Color Histogram stream."""
    def __init__(self, input_dim, output_dim=256):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, 256),
            nn.BatchNorm1d(256),
            nn.ReLU(inplace=True),
            nn.Dropout(0.3),
            nn.Linear(256, output_dim),
            nn.ReLU(inplace=True),
        )
    def forward(self, x): 
        return self.net(x)


class CGIMIF_CPU(nn.Module):
    """
    CG-IMIF — phiên bản đơn giản hóa, chạy ổn định trên CPU
    """
    def __init__(self, num_classes, hist_bins=32, fusion_dim=256):
        super().__init__()
        hist_input_dim = hist_bins * 3

        # Backbone: MobileNetV3-Small
        self.backbone = models.mobilenet_v3_small(weights='IMAGENET1K_V1')
        
        # Bỏ classifier gốc
        self.backbone.classifier = nn.Identity()
        
        # Global pooling
        self.global_pool = nn.AdaptiveAvgPool2d(1)
        
        # Projection layer cho visual features
        self.vis_proj = nn.Sequential(
            nn.Flatten(),
            nn.Linear(576, 256),  # 576 là output channels của MobileNetV3-Small
            nn.BatchNorm1d(256),
            nn.ReLU(inplace=True),
            nn.Dropout(0.4),
        )
        
        # Color Histogram encoder
        self.hist_encoder = HistEncoder(hist_input_dim, output_dim=256)
        
        # Final classifier
        self.classifier = nn.Sequential(
            nn.Linear(256 + 256, fusion_dim),
            nn.BatchNorm1d(fusion_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(0.4),
            nn.Linear(fusion_dim, num_classes),
        )

    def forward(self, rgb, edge, hist):
        # Visual features từ RGB
        feat_rgb = self.backbone.features(rgb)      # [B, 576, H, W]
        feat_rgb = self.global_pool(feat_rgb)       # [B, 576, 1, 1]
        feat_rgb = self.vis_proj(feat_rgb)          # [B, 256]
        
        # Visual features từ Edge
        feat_edge = self.backbone.features(edge)    # [B, 576, H, W]
        feat_edge = self.global_pool(feat_edge)     # [B, 576, 1, 1]
        feat_edge = self.vis_proj(feat_edge)        # [B, 256]
        
        # Fusion visual (mean)
        feat_vis = (feat_rgb + feat_edge) / 2
        
        # Histogram features
        feat_hist = self.hist_encoder(hist)         # [B, 256]
        
        # Concatenate và classify
        feat = torch.cat([feat_vis, feat_hist], dim=1)  # [B, 512]
        return self.classifier(feat)


# Khởi tạo model
model = CGIMIF_CPU(
    num_classes=NUM_CLASSES,
    hist_bins=CFG['hist_bins'],
    fusion_dim=CFG['fusion_dim'],
).to(DEVICE)

# Kiểm tra
with torch.no_grad():
    d_rgb  = torch.randn(2, 3, CFG['img_size'], CFG['img_size'])
    d_edge = torch.randn(2, 3, CFG['img_size'], CFG['img_size'])
    d_hist = torch.randn(2, CFG['hist_bins'] * 3)
    out = model(d_rgb, d_edge, d_hist)
    
    total_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f'✅ Output shape: {out.shape}')
    print(f'✅ Params: {total_params/1e6:.2f}M')





criterion = nn.CrossEntropyLoss(label_smoothing=0.1)
optimizer = torch.optim.AdamW(
    model.parameters(), lr=CFG['lr'], weight_decay=CFG['weight_decay']
)
scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(
    optimizer, T_max=CFG['epochs'], eta_min=1e-6
)
print('Optimizer ready ✓')


def run_epoch(model, loader, optimizer, criterion, device, train=True, desc=''):
    model.train() if train else model.eval()
    total_loss, correct, total = 0.0, 0, 0
    ctx = torch.enable_grad() if train else torch.no_grad()

    with ctx:
        for rgb, edge, hist, labels in tqdm(loader, desc=desc, leave=False):
            rgb    = rgb.to(device)
            edge   = edge.to(device)
            hist   = hist.to(device)
            labels = labels.to(device)

            if train: optimizer.zero_grad()
            logits = model(rgb, edge, hist)
            loss   = criterion(logits, labels)
            if train:
                loss.backward()
                torch.nn.utils.clip_grad_norm_(model.parameters(), 5.0)
                optimizer.step()

            total_loss += loss.item() * labels.size(0)
            correct    += (logits.argmax(1) == labels).sum().item()
            total      += labels.size(0)

    return total_loss / total, correct / total


history = {'train_loss':[], 'train_acc':[], 'val_loss':[], 'val_acc':[]}
best_acc  = 0.0
CKPT_PATH = '/kaggle/working/best_cgimif_cpu.pth'

for epoch in range(1, CFG['epochs'] + 1):
    tr_loss, tr_acc = run_epoch(model, train_dl, optimizer, criterion,
                                DEVICE, train=True,
                                desc=f'E{epoch}/{CFG["epochs"]} Train')
    vl_loss, vl_acc = run_epoch(model, val_dl, optimizer, criterion,
                                DEVICE, train=False,
                                desc=f'E{epoch}/{CFG["epochs"]} Val')
    scheduler.step()

    history['train_loss'].append(tr_loss)
    history['train_acc'].append(tr_acc)
    history['val_loss'].append(vl_loss)
    history['val_acc'].append(vl_acc)

    tag = ' ← best' if vl_acc > best_acc else ''
    print(f'Ep {epoch:02d} | Train {tr_loss:.4f}/{tr_acc:.4f} '
          f'| Val {vl_loss:.4f}/{vl_acc:.4f}{tag}')

    if vl_acc > best_acc:
        best_acc = vl_acc
        torch.save({
            'epoch': epoch, 'model_state': model.state_dict(),
            'val_acc': vl_acc, 'num_classes': NUM_CLASSES,
            'label2idx': label2idx, 'idx2label': idx2label, 'cfg': CFG,
        }, CKPT_PATH)

print(f'\nBest Val Acc: {best_acc:.4f}')





fig, axes = plt.subplots(1, 2, figsize=(12, 4))
for ax, key, title in zip(axes, ['loss', 'acc'], ['Loss', 'Accuracy']):
    ax.plot(history[f'train_{key}'], label='Train')
    ax.plot(history[f'val_{key}'],   label='Val')
    ax.set_title(title); ax.set_xlabel('Epoch')
