inspect_dir(TRAIN_PRES_IMG)
inspect_dir(TRAIN_PRES_LBL)


# ─── Parse samples dựa trên kết quả debug phía trên ──────────────────────
# Hàm này tự động detect cả 3 kiểu cấu trúc phổ biến:
#   A) pill/image/<class_id>/<img>.jpg   → subfolders = class
#   B) pill/image/<img>.jpg + pill/label/<img>.json  → flat + json label
#   C) prescription/image + prescription/label       → crop từ bbox

def build_samples(pill_img_dir, pill_lbl_dir=None, max_samples=None):
    pill_img_dir = Path(pill_img_dir)
    samples = []

    subdirs = [d for d in pill_img_dir.iterdir() if d.is_dir()]

    # ── Case A: subfolder per class ──────────────────────────────────────
    if subdirs:
        print(f'[Mode A] Subfolder per class — {len(subdirs)} classes')
        for class_dir in subdirs:
            try:
                label_id = int(class_dir.name)
            except ValueError:
                # Tên thư mục không phải số → dùng hash
                label_id = abs(hash(class_dir.name)) % 10000
            for img_file in class_dir.iterdir():
                if img_file.suffix.lower() in ['.jpg', '.jpeg', '.png', '.bmp']:
                    samples.append((str(img_file), label_id))

    # ── Case B: flat folder + JSON labels ────────────────────────────────
    elif pill_lbl_dir and Path(pill_lbl_dir).exists():
        print('[Mode B] Flat folder + JSON label files')
        pill_lbl_dir = Path(pill_lbl_dir)
        for img_file in pill_img_dir.iterdir():
            if img_file.suffix.lower() not in ['.jpg', '.jpeg', '.png', '.bmp']:
                continue
            lbl_file = pill_lbl_dir / (img_file.stem + '.json')
            if not lbl_file.exists():
                continue
            with open(lbl_file) as f:
                data = json.load(f)
            # Label file có thể là list of boxes hoặc single label
            if isinstance(data, list):
                for box in data:
                    samples.append((str(img_file), box['label']))
            elif isinstance(data, dict) and 'label' in data:
                samples.append((str(img_file), data['label']))

    else:
        print('[Mode ?] Không rõ cấu trúc — kiểm tra lại output cell Debug')
        return []

    print(f'Tổng samples: {len(samples)}')

    # Remap label → contiguous 0..N-1
    unique_labels = sorted(set(s[1] for s in samples))
    l2i = {l: i for i, l in enumerate(unique_labels)}
    samples = [(p, l2i[l]) for p, l in samples]

    # Giới hạn samples nếu cần (CPU mode)
    if max_samples and len(samples) > max_samples:
        np.random.shuffle(samples)
        samples = samples[:max_samples]
        print(f'Giới hạn còn {max_samples} samples (CPU mode)')

    return samples, l2i, {i: l for l, i in l2i.items()}


