# ─── Xem cấu trúc thực tế của dataset ────────────────────────────────────
def inspect_dir(path, max_show=8):
    path = Path(path)
    if not path.exists():
        print(f'[!] Không tìm thấy: {path}')
        return
    items = sorted(path.iterdir())
    dirs  = [i for i in items if i.is_dir()]
    files = [i for i in items if i.is_file()]
    print(f'\n📁 {path}')
    print(f'   Subdirs : {len(dirs)}   |   Files: {len(files)}')
    if dirs:
        print('   Subdirs (mẫu):', [d.name for d in dirs[:max_show]])
        # Xem bên trong subdir đầu tiên
        sub_files = list(dirs[0].iterdir())[:max_show]
        print(f'   → Bên trong "{dirs[0].name}"/:', [f.name for f in sub_files])
    if files:
        print('   Files (mẫu):', [f.name for f in files[:max_show]])

